{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "game",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const PORT=process.env.PORT||3000;const root='C:/Users/admin/Desktop/test/game';const s=http.createServer((req,res)=>{let f=path.join(root,req.url==='/'?'index.html':req.url);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end();}else{const ext=path.extname(f).slice(1);const m={html:'text/html',png:'image/png',js:'text/javascript',css:'text/css'};res.writeHead(200,{'Content-Type':m[ext]||'application/octet-stream'});res.end(d);}});});s.listen(PORT,()=>console.log('Listening on '+PORT));"],
      "port": 3001,
      "autoPort": true
    }
  ]
}
